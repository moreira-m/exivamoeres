# ============================================================
# Exivamoeres — variáveis de ambiente (desenvolvimento local)
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env.
# ============================================================

# ----- Banco de dados (usado pelo docker-compose e pelo backend) -----
POSTGRES_DB=exivamoeres
POSTGRES_USER=exivamoeres
POSTGRES_PASSWORD=troque-esta-senha
# URL JDBC vista pelo backend. Fora do Docker use localhost; dentro do
# docker-compose o host é "postgres" (nome do serviço).
DATABASE_URL=jdbc:postgresql://localhost:5432/exivamoeres

# ----- JWT -----
# Segredo HMAC com no mínimo 64 caracteres (HS512). Gere com:
#   openssl rand -base64 64
JWT_SECRET=
# Validade do access token em minutos
JWT_ACCESS_TOKEN_MINUTES=30
# Validade do refresh token em dias
JWT_REFRESH_TOKEN_DAYS=14

# ----- OAuth2 (crie as aplicações nos portais de cada provedor) -----
# Discord: https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- Frontend -----
# Origem permitida no CORS. Em produção, o domínio do Netlify.
FRONTEND_URL=http://localhost:5173
# Para onde o backend redireciona após login OAuth2 bem-sucedido
# (o token JWT vai como fragmento na URL).
OAUTH2_REDIRECT_URL=http://localhost:5173/oauth/callback

# ----- TibiaData API -----
# API pública, sem chave. Só troque se for usar um mirror/self-hosted.
TIBIADATA_BASE_URL=https://api.tibiadata.com

# ----- Cache (elegibilidade de personagem e worlds) -----
# TTL da checagem de world + Free/Premium por personagem. Curto o bastante
# para não travar um char que virou Premium; longo o bastante para não bater
# na TibiaData a cada ação. Aceita formato de Duration (1h, 30m, 90s...).
CHARACTER_ELIGIBILITY_CACHE_TTL=1h
# TTL da lista de worlds (muda muito raramente).
WORLDS_CACHE_TTL=24h

# ----- Chat -----
# Rate limit de mensagens de chat por usuário (mensagens por minuto).
CHAT_MESSAGES_PER_MINUTE=20

# ----- Times / planos -----
# Máximo de times ATIVOS simultâneos numa conta free.
TEAM_FREE_ACTIVE_LIMIT=3
# Prazo de vida de um time por plano (dias).
TEAM_FREE_DURATION_DAYS=7
TEAM_PREMIUM_DURATION_DAYS=30
# Frequência do job que arquiva times expirados.
TEAM_EXPIRATION_CHECK_INTERVAL=1h

# ----- Verificação de personagem -----
# Frequência do polling de verificação de claim.
CLAIM_POLL_INTERVAL=15m

# ----- Refresh de level (exibição) -----
# Job que mantém o level exibido atualizado. Custo mínimo: só personagens em
# time ativo e com retrato mais velho que a validade são rebuscados, em lote.
# Aumente o intervalo/validade ou reduza o lote para gastar ainda menos.
CHARACTER_LEVEL_REFRESH_INTERVAL=1h
CHARACTER_LEVEL_STALENESS=12h
CHARACTER_LEVEL_REFRESH_BATCH_SIZE=15
CHARACTER_LEVEL_REFRESH_SPACING=2s

# ----- Stripe (Fase 2 — só quando o código do Stripe existir) -----
# Ver docs/configuracoes-externas.md, seção 5. Usar chaves de TESTE primeiro.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=

# ----- Perfil do Spring -----
SPRING_PROFILES_ACTIVE=dev

# ----- Notas de produção -----
# WebSocket (chat): o endpoint /ws usa a MESMA origem de FRONTEND_URL no CORS.
# Em produção, FRONTEND_URL deve ser o domínio do Netlify (https://...).
# OAUTH2_REDIRECT_URL deve apontar para <FRONTEND_URL>/oauth/callback.
# Guia completo das integrações externas: docs/configuracoes-externas.md
